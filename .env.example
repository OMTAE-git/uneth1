# Autonomous ADA Compliance Engine Configuration

# SMTP Settings for Email Delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Sender Info
FROM_EMAIL=compliance@example.com
FROM_NAME=ADA Compliance Team
FROM_ORG=Web Accessibility Services
FROM_PHONE=555-555-5555

# Engine Settings
CHECK_INTERVAL_HOURS=24
MAX_SITES_PER_RUN=50
AUTO_SEND=true
AUTO_DISCOVER=true
